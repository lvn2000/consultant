{
  "name": "consultant-specialist-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NUXT_DEVTOOLS_PORT=24683 NUXT_DEVTOOLS_UI_PORT=24683 NITRO_DEV_HMR_PORT=24683 VITE_HMR_PORT=24683 NUXT_HMR_PORT=24683 nuxi dev --port 3003 --hmr-port 24683 --devtools false",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "audit": "npm audit --audit-level=moderate",
    "audit:fix": "npm audit fix",
    "license:check": "node ../scripts/add-license-headers.js --check .",
    "license:add": "node ../scripts/add-license-headers.js --add ."
  },
  "dependencies": {
    "@nuxt/icon": "^1.10.0",
    "@nuxtjs/i18n": "^10.2.3",
    "@pinia/nuxt": "^0.7.0",
    "@primevue/nuxt-module": "^4.2.6",
    "nuxt": "^4.2.2",
    "pinia": "^2.3.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.2.6",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitest/ui": "^3.2.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.17.0",
    "happy-dom": "^20.1.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^3.2.0",
    "vue-tsc": "^2.2.0"
  }
}
