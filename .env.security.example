# Переменные окружения для безопасности

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-64-chars
JWT_ISSUER=consultant-api
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# Database Encryption (для pgcrypto)
DB_ENCRYPTION_KEY=your-database-encryption-key-change-this

# Session Configuration
SESSION_SECRET=your-session-secret-key-change-this

# Security
ACCOUNT_LOCK_DURATION_MINUTES=15
MAX_LOGIN_ATTEMPTS=5

# CORS (comma-separated domains)
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Rate Limiting (if not using nginx)
RATE_LIMIT_REQUESTS_PER_SECOND=100
RATE_LIMIT_BURST=200

# Production security flags
FORCE_HTTPS=true
SECURE_COOKIES=true
ENABLE_CSRF_PROTECTION=true
