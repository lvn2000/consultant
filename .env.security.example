# Environment variables for security configuration

# JWT Configuration (JWT_SECRET is required and must be changed for production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-64-chars
JWT_ISSUER=consultant-api
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Legacy authentication (for backward compatibility)
LEGACY_AUTH_ENABLED=true

# OIDC Configuration (optional, set OIDC_ENABLED=true to enable)
OIDC_ENABLED=false
OIDC_ISSUER=https://keycloak.example.com/realms/consultant
OIDC_JWKS_URI=https://keycloak.example.com/realms/consultant/protocol/openid-connect/certs
OIDC_AUDIENCE=consultant-api
OIDC_ALLOWED_ALGS=RS256,ES256
OIDC_JWKS_CACHE_SECONDS=600
OIDC_JWKS_TIMEOUT_SECONDS=10
