# ============================================
# GCP Environment Configuration Template
# ============================================
# This file contains environment variables for deploying the Consultant Platform
# to Google Cloud Platform. Copy this file to .env or set these variables in
# your deployment environment.
#
# Most values are automatically generated by the deploy-gcp.sh script and
# stored in Google Cloud Secret Manager. You typically don't need to set these
# manually unless you're doing a manual deployment.
#
# Sections:
# 1. GCP Project Configuration
# 2. Cloud SQL Database Configuration
# 3. Application Configuration
# 4. Security Configuration
# 5. HTTPS Configuration
# 6. Custom Domain Configuration (Optional)
# 7. Service URLs (Auto-generated)
# ============================================

# ============================================
# 1. GCP Project Configuration
# ============================================

# GCP Project ID (REQUIRED)
# The ID of your Google Cloud Platform project
# Example: consultant-platform-prod
GCP_PROJECT_ID=your-project-id

# GCP Region (OPTIONAL, default: us-central1)
# The region where resources will be deployed
# Example: us-central1, europe-west1, asia-northeast1
GCP_REGION=us-central1

# GCP Billing Account ID (OPTIONAL but recommended)
# Needed for creating new projects or linking billing
# Example: 012345-6789AB-CDEF01
GCP_BILLING_ACCOUNT=your-billing-account-id

# Environment (REQUIRED)
# Deployment environment: dev, staging, or prod
ENVIRONMENT=prod

# ============================================
# 2. Cloud SQL Database Configuration
# ============================================
# These values are automatically generated by deploy-gcp.sh and stored in
# Secret Manager. You can retrieve them with:
# gcloud secrets versions access latest --secret=consultant-db-password-${ENVIRONMENT}

# Database URL (Auto-generated)
# Format: jdbc:postgresql://[PRIVATE_IP]:5432/consultant
# Use private IP for production, public IP for development
DB_URL=jdbc:postgresql://10.0.0.1:5432/consultant

# Database User (Auto-generated)
DB_USER=consultant_user

# Database Password (Auto-generated, stored in Secret Manager)
DB_PASSWORD=generated-password-here

# Database Connection Pool Size (OPTIONAL)
DB_POOL_SIZE=32

# Database Driver
DB_DRIVER=org.postgresql.Driver

# ============================================
# 3. Application Configuration
# ============================================

# Server Host (OPTIONAL, default: 0.0.0.0)
SERVER_HOST=0.0.0.0

# Server Port (OPTIONAL, default: 8090)
SERVER_PORT=8090

# Use AWS Services (OPTIONAL, default: false)
# Set to true if using AWS S3, SES, SNS, SQS
USE_AWS=false

# AWS Region (if USE_AWS=true)
AWS_REGION=us-east-1

# Local Storage Path (if USE_AWS=false)
LOCAL_STORAGE_PATH=./storage

# ============================================
# 4. Security Configuration
# ============================================
# These values are automatically generated by deploy-gcp.sh and stored in
# Secret Manager.

# JWT Secret (Auto-generated, stored in Secret Manager)
# Used for signing JSON Web Tokens
JWT_SECRET=generated-jwt-secret-here

# JWT Issuer (OPTIONAL)
JWT_ISSUER=consultant-api

# JWT Access Token TTL (OPTIONAL)
JWT_ACCESS_TTL=15m

# JWT Refresh Token TTL (OPTIONAL)
JWT_REFRESH_TTL=7d

# Database Encryption Key (Auto-generated, stored in Secret Manager)
DB_ENCRYPTION_KEY=generated-encryption-key-here

# Session Secret (Auto-generated, stored in Secret Manager)
SESSION_SECRET=generated-session-secret-here

# Max Login Attempts (OPTIONAL)
MAX_LOGIN_ATTEMPTS=5

# Account Lock Duration (OPTIONAL)
ACCOUNT_LOCK_DURATION_MINUTES=15

# ============================================
# 5. HTTPS Configuration
# ============================================

# Force HTTPS (REQUIRED for production)
# Redirects HTTP to HTTPS and enforces secure connections
FORCE_HTTPS=true

# Secure Cookies (REQUIRED for production)
# Cookies only sent over HTTPS
SECURE_COOKIES=true

# Secure Sessions (REQUIRED for production)
# Sessions require HTTPS
SESSION_SECURE=true

# Enable HTTP/2 (OPTIONAL, default: true)
ENABLE_HTTP2=true

# Security Headers (OPTIONAL, default: true)
SECURITY_HEADERS=true

# ============================================
# 6. Custom Domain Configuration (Optional)
# ============================================
# Only set these if using custom domains with Cloud Run

# Custom Domain Base (e.g., yourdomain.com)
# If set, individual service domains will be auto-generated:
# - Backend: api.yourdomain.com
# - Client App: app.yourdomain.com
# - Admin App: admin.yourdomain.com
# - Specialist App: specialist.yourdomain.com
CUSTOM_DOMAIN=yourdomain.com

# OR specify individual domains:

# Backend API Domain
BACKEND_DOMAIN=api.yourdomain.com

# Client App Domain
CLIENT_DOMAIN=app.yourdomain.com

# Admin App Domain
ADMIN_DOMAIN=admin.yourdomain.com

# Specialist App Domain
SPECIALIST_DOMAIN=specialist.yourdomain.com

# ============================================
# 7. Service URLs (Auto-generated)
# ============================================
# These URLs are automatically generated by Cloud Run.
# They follow the pattern: https://SERVICE-[HASH]-REGION.a.run.app
# You can retrieve them with:
# gcloud run services list --region=${GCP_REGION} --format="value(URL)"

# Backend Service URL (Auto-generated)
BACKEND_URL=https://consultant-backend-abc123-uc.a.run.app

# Client App URL (Auto-generated)
CLIENT_APP_URL=https://consultant-client-app-def456-uc.a.run.app

# Admin App URL (Auto-generated)
ADMIN_APP_URL=https://consultant-admin-app-ghi789-uc.a.run.app

# Specialist App URL (Auto-generated)
SPECIALIST_APP_URL=https://consultant-specialist-app-jkl012-uc.a.run.app

# ============================================
# 8. Frontend Configuration
# ============================================
# These variables are used by Nuxt.js frontend applications

# API Base URL
# Should point to the backend service URL
NUXT_PUBLIC_API_BASE=${BACKEND_URL}/api

# Site URL for SEO and social sharing
NUXT_PUBLIC_SITE_URL=${CLIENT_APP_URL}

# ============================================
# 9. Monitoring and Logging
# ============================================

# Log Level (OPTIONAL)
# Options: TRACE, DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# Enable Metrics (OPTIONAL)
ENABLE_METRICS=true

# Enable Tracing (OPTIONAL)
ENABLE_TRACING=false

# ============================================
# Notes:
# ============================================
#
# 1. Automatic Value Generation:
#    The deploy-gcp.sh script automatically generates:
#    - DB_PASSWORD
#    - JWT_SECRET
#    - DB_ENCRYPTION_KEY
#    - SESSION_SECRET
#    And stores them in Google Cloud Secret Manager.
#
# 2. Secret Manager Access:
#    To retrieve a secret:
#    gcloud secrets versions access latest --secret=SECRET_NAME-${ENVIRONMENT}
#
# 3. Environment Variables in Cloud Run:
#    When deploying with deploy-gcp.sh, environment variables are automatically
#    set in Cloud Run services. You don't need to manually set them unless
#    you're doing a custom deployment.
#
# 4. Custom Domains:
#    If using custom domains, you must:
#    a) Verify domain ownership in Google Cloud
#    b) Configure DNS records as shown by deploy-gcp.sh
#    c) Wait for SSL certificate provisioning (up to 30 minutes)
#
# 5. Database Access:
#    - Development: Uses public IP (less secure, easier access)
#    - Production: Uses private IP with VPC Connector (more secure)
#
# 6. Cost Optimization:
#    - Development: Use db-f1-micro tier
#    - Staging: Use db-g1-small tier
#    - Production: Use db-custom-2-7680 or higher
#
# ============================================
# Quick Reference Commands:
# ============================================
#
# Deploy to GCP:
#   ./deploy-gcp.sh [dev|staging|prod] [options]
#
# Test HTTPS configuration:
#   ./test-gcp-https.sh [dev|staging|prod] --project=${GCP_PROJECT_ID}
#
# View service URLs:
#   gcloud run services list --region=${GCP_REGION}
#
# View logs:
#   gcloud logging read "resource.type=cloud_run_revision" --limit=20
#
# Connect to database:
#   gcloud sql connect consultant-postgres-${ENVIRONMENT} --user=postgres
#
# Rotate secrets:
#   gcloud secrets versions add consultant-db-password-${ENVIRONMENT} \
#     --data-file=<(openssl rand -base64 32)
#
# ============================================
