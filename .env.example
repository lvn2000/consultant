# Example configuration file
# Copy to .env or set as environment variables

# Server configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8090

# Database configuration
DB_DRIVER=org.postgresql.Driver
DB_URL=jdbc:postgresql://localhost:5432/consultant
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_SIZE=32

# AWS configuration (set USE_AWS=true to enable)
USE_AWS=false
AWS_REGION=us-east-1
AWS_S3_BUCKET=consultant-files
AWS_SQS_QUEUE_PREFIX=consultant
AWS_SENDER_EMAIL=[email protected]

# Local storage (used when USE_AWS=false)
LOCAL_STORAGE_PATH=./storage

# JWT Configuration (JWT_SECRET is required - change for production)
JWT_SECRET=dev-change-this-jwt-secret-in-production-use-min-64-chars
JWT_ISSUER=consultant-api
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Legacy authentication (for backward compatibility)
LEGACY_AUTH_ENABLED=true
