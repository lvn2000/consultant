# Infisical configuration for Docker Compose
# Copy to .env.infisical and fill with your values

# Получите service token:
# 1. Login: infisical login
# 2. Create token: infisical service-token --env=production
INFISICAL_TOKEN=st.prod.your-token-here

# Project ID из Infisical UI
# Settings → General → Project ID
INFISICAL_PROJECT_ID=your-project-id-here

# Environment: development, staging, production
INFISICAL_ENVIRONMENT=production

# PostgreSQL credentials (будут заменены на те, что в Infisical)
# Эти используются только для bootstrap, потом берутся из Infisical
POSTGRES_USER=consultant
POSTGRES_PASSWORD=temp-password

# Redis password (временный, заменится на Infisical)
REDIS_PASSWORD=temp-redis-password
